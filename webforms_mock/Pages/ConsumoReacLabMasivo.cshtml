@page "/Inventarios/ConsumoReacLabMasivo.aspx"
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@model QuimiOSWebForms.Pages.ConsumoReacLabMasivoModel
@{
    Layout = "_Layout";
    var token = Antiforgery.GetAndStoreTokens(HttpContext);
}

<!DOCTYPE html>
<html>
<head>
    <title>Consumo de Reactivo Laboratorio Masivo</title>
    <meta charset="utf-8">
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }
        .search-box { margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 4px; }
        .grid-container { background: white; border: 1px solid #dee2e6; border-radius: 4px; overflow: hidden; }
        table { width: 100%; border-collapse: collapse; }
        th { background: #e9ecef; padding: 10px; border: 1px solid #dee2e6; font-weight: bold; text-align: left; }
        td { padding: 8px; border: 1px solid #dee2e6; }
        .wd090 { width: 90px; font-weight: bold; }
        .wd060 { width: 60px; }
        .wd080 { width: 80px; }
        .wd100 { width: 100px; }
        input[type="text"] { width: 100%; padding: 4px; border: 1px solid #ddd; border-radius: 3px; box-sizing: border-box; }
        select { width: 100%; padding: 4px; border: 1px solid #ddd; border-radius: 3px; }
        .btn { padding: 8px 16px; background: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer; }
        .btn:hover { background: #2980b9; }
        .btn-success { background: #27ae60; }
        .btn-success:hover { background: #219a52; }
        .error { color: red; margin: 10px 0; padding: 10px; background: #ffe6e6; border-radius: 4px; }
        .success { color: green; margin: 10px 0; padding: 10px; background: #e6ffe6; border-radius: 4px; }
        .hidden { display: none; }
    </style>
</head>
<body>
    <form id="aspnetForm" method="post">
        <input name="@token.FormFieldName" type="hidden" value="@token.RequestToken"/>
        <input type="hidden" name="__VIEWSTATE" id="__VIEWSTATE" value="@Model.ViewState">
        <input type="hidden" name="__VIEWSTATEGENERATOR" id="__VIEWSTATEGENERATOR" value="@Model.ViewStateGenerator">
        <input type="hidden" name="__EVENTVALIDATION" id="__EVENTVALIDATION" value="@Model.EventValidation">
        <input type="hidden" name="ctl00$ContentMasterPage$ScriptManager1" id="ctl00_ContentMasterPage_ScriptManager1" value="ctl00$ContentMasterPage$UpdatePanel1|ctl00$ContentMasterPage$btnBuscarEstudio">
        <input type="hidden" name="ctl00$ContentMasterPage$hfActivo" id="ctl00_ContentMasterPage_hfActivo" value="@Model.HfActivo">
        <input type="hidden" name="ctl00$ContentMasterPage$hfCalcAuto" id="ctl00_ContentMasterPage_hfCalcAuto" value="@Model.HfCalcAuto">

        <div class="search-box">
            <h3>Consumo de Reactivo Laboratorio Masivo</h3>
            <div style="display: flex; gap: 15px; align-items: center;">
                <div>
                    <label for="ctl00_ContentMasterPage_ddlSuc">Sucursal:</label>
                    <select id="ctl00_ContentMasterPage_ddlSuc" name="ctl00$ContentMasterPage$ddlSuc">
                        <option value="1" selected>Monterrey</option>
                        <option value="2">Celaya</option>
                        <option value="3">Tijuana</option>
                        <option value="4">Puebla</option>
                        <option value="5">Merida</option>
                    </select>
                </div>
                <div>
                    <label for="ctl00_ContentMasterPage_ddlEquipo">Equipo:</label>
                    <select id="ctl00_ContentMasterPage_ddlEquipo" name="ctl00$ContentMasterPage$ddlEquipo">
                        <option value="" selected>[Seleccione]</option>
                        <option value="60">ARCHITECT ci8200</option>
                        <option value="59">ARCHITECT i1000</option>
                        <option value="12">ARCHITECT c8000</option>
                    </select>
                </div>
                <div>
                    <label for="ctl00_ContentMasterPage_txtFecDesde">Desde:</label>
                    <input type="text" id="ctl00_ContentMasterPage_txtFecDesde" name="ctl00$ContentMasterPage$txtFecDesde" value="@Model.FechaDesde" style="width: 100px;">
                </div>
                <div>
                    <label for="ctl00_ContentMasterPage_txtFecHasta">Hasta:</label>
                    <input type="text" id="ctl00_ContentMasterPage_txtFecHasta" name="ctl00$ContentMasterPage$txtFecHasta" value="@Model.FechaHasta" style="width: 100px;">
                </div>
                <button type="submit" class="btn" id="ctl00_ContentMasterPage_btnBuscarEstudio" name="ctl00$ContentMasterPage$btnBuscarEstudio" value="Buscar">Buscar</button>
            </div>
            <div style="margin-top: 10px;">
                <span>Usuario: <strong>@Model.LoggedInUser</strong></span>
                <span style="margin-left: 20px;">Total de Registros encontrados: <strong>@Model.Records.Count</strong></span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="success">@Model.SuccessMessage</div>
        }

        <div class="grid-container">
            <table id="ctl00_ContentMasterPage_grdConsumo">
                <thead>
                    <tr>
                        <th class="wd090">Reactivo</th>
                        <th class="wd060">Stock</th>
                        <th class="wd080">Pacientes</th>
                        <th class="wd080">Repeticiones</th>
                        <th class="wd080">Control</th>
                        <th class="wd080">Calibracion</th>
                        <th class="wd080">Cancelacion</th>
                        <th class="wd100">Motivo</th>
                        <th class="wd060">Validacion</th>
                        <th class="wd060">Sin Ident.</th>
                        <th class="wd080">Motivo Sin Ident.</th>
                        <th class="wd060">Proveedor</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Records.Count; i++)
                    {
                        var record = Model.Records[i];
                        var rowIndex = (i + 2).ToString("D2");
                        <tr>
                            <td class="wd090">
                                <span id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_lblRVO" class="wd090">@record.ReagentCode</span>
                                <input type="hidden" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_hfIDProducto" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$hfIDProducto" value="@record.ProductId">
                                <input type="hidden" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_hfActivo" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$hfActivo" value="@record.Activo">
                                <input type="hidden" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_hfCalcAuto" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$hfCalcAuto" value="@record.CalcAuto">
                            </td>
                            <td class="wd060">
                                <span id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_lblExistFinal">@record.Stock</span>
                            </td>
                            <td class="wd080">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtPacientes" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtPacientes" value="@record.Pacientes" class="wd080">
                            </td>
                            <td class="wd080">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtRepeticiones" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtRepeticiones" value="@record.Repeticiones" class="wd080">
                            </td>
                            <td class="wd080">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtControlCapMGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtControlCapMGrd" value="@record.Control" class="wd080">
                            </td>
                            <td class="wd080">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtCalibracionCapMGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtCalibracionCapMGrd" value="@record.Calibracion" class="wd080">
                            </td>
                            <td class="wd080">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtCancelacionCapMGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtCancelacionCapMGrd" value="@record.Cancelacion" class="wd080">
                            </td>
                            <td class="wd100">
                                <select id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_cmbMotCancelacionGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$cmbMotCancelacionGrd">
                                    <option value="" selected=@(string.IsNullOrEmpty(record.MotivoCancelacion))>[Seleccione]</option>
                                    <option value="1" selected=@(record.MotivoCancelacion == "1")>Calibracion</option>
                                    <option value="2" selected=@(record.MotivoCancelacion == "2")>Control</option>
                                    <option value="3" selected=@(record.MotivoCancelacion == "3")>Repeticion</option>
                                    <option value="4" selected=@(record.MotivoCancelacion == "4")>Otro</option>
                                </select>
                            </td>
                            <td class="wd060">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtValidacionCapMGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtValidacionCapMGrd" value="@record.Validacion" class="wd060" readonly>
                            </td>
                            <td class="wd060">
                                <input type="text" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_txtSinIdentificarCapMGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$txtSinIdentificarCapMGrd" value="@record.SinIdentificar" class="wd060" readonly>
                            </td>
                            <td class="wd080">
                                <select id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_cmbMotSinIdentificarGrd" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$cmbMotSinIdentificarGrd">
                                    <option value="[Seleccione]" selected>[Seleccione]</option>
                                </select>
                            </td>
                            <td class="wd060">
                                <input type="checkbox" id="ctl00_ContentMasterPage_grdConsumo_ctl@(rowIndex)_chkQueProveedor" name="ctl00$ContentMasterPage$grdConsumo$ctl@(rowIndex)$chkQueProveedor" @(record.QueProveedor ? "checked" : "") value="on">
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="margin-top: 20px; text-align: center;">
            <button type="submit" class="btn btn-success" id="ctl00_ContentMasterPage_btnGuardaMasivo" name="ctl00$ContentMasterPage$btnGuardaMasivo" value="Guardar">Guardar Masivo</button>
        </div>
    </form>
</body>
</html>
