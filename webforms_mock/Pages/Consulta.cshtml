@page "/Consulta"
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@model QuimiOSWebForms.Pages.ConsultaModel
@{
    Layout = "_Layout";
    var token = Antiforgery.GetAndStoreTokens(HttpContext);
    var currentPage = Model.CurrentPage;
    var totalPages = Model.TotalPages;
}

<!DOCTYPE html>
<html>
<head>
    <title>Consulta Ordenes de Trabajo</title>
</head>
<body>
    <form id="aspnetForm" method="post">
        <input name="@token.FormFieldName" type="hidden" value="@token.RequestToken"/>
        <input type="hidden" name="__VIEWSTATE" id="__VIEWSTATE" value="@Model.ViewState">
        <input type="hidden" name="__VIEWSTATEGENERATOR" id="__VIEWSTATEGENERATOR" value="@Model.ViewStateGenerator">
        <input type="hidden" name="__EVENTVALIDATION" id="__EVENTVALIDATION" value="@Model.EventValidation">
        
        <div style="margin: 20px;">
            <div style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 4px;">
                <h3>Busqueda de Ordenes de Trabajo</h3>
                <div style="display: flex; gap: 10px; align-items: center;">
                    <label for="txtCliente">Cliente:</label>
                    <input type="text" id="ctl00_ContentMasterPage_txtcliente" name="ctl00_ContentMasterPage_txtcliente" value="@Model.ClientId" style="padding: 8px; width: 100px;">
                    <input type="submit" id="ctl00_ContentMasterPage_btnBuscar" name="ctl00_ContentMasterPage_btnBuscar" value="Buscar" style="padding: 8px 16px;">
                    <span style="margin-left: 20px;">Usuario: <span id="ctl00_ContentMasterPage_lblUsuarioCaptura">@Model.LoggedInUser</span></span>
                </div>
            </div>
            
            <table id="ctl00_ContentMasterPage_grdConsultaOT" style="width: 100%; border-collapse: collapse; background: white;">
                <thead>
                    <tr style="background: #e9ecef;">
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Fecha</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Recep</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Folio</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Cliente</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Paciente</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Est/Per</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Prueba</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">FecCapRes</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">FecLibera</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">SucProc</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Maquilador</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">Prioridad</th>
                        <th style="padding: 10px; border: 1px solid #dee2e6;">FecNac</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Records.Count; i++)
                    {
                        var record = Model.Records[i];
                        var rowIndex = (i + 2).ToString("D2");
                        <tr>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFechaGrd">@record.Fecha</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFechaRecep">@record.FechaRecep</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFolioGrd">@record.Folio</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblClienteGrd">@record.Cliente</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblPacienteGrd">@record.Paciente</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblEstPerGrd">@record.EstPer</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_Label1">@record.Prueba</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFecCapRes">@record.FecCapRes</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFecLibera">@record.FecLibera</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblSucProc">@record.SucProc</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblMaquilador">@record.Maquilador</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_Label3">@record.Prioridad</span>
                            </td>
                            <td style="padding: 8px; border: 1px solid #dee2e6;">
                                <span id="ctl00_ContentMasterPage_grdConsultaOT_ctl@(rowIndex)_lblFecNac">@record.FecNac</span>
                            </td>
                        </tr>
                    }
                    <tr style="background: #f8f9fa;">
                        <td colspan="13" style="padding: 10px; text-align: center;">
                            Pagina @currentPage de @totalPages
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </form>
</body>
</html>